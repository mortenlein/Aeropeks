{
  "productName": "Aeropeks",
  "version": "0.1.4",
  "identifier": "com.aeropeks.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aeropeks",
        "width": 1920,
        "height": 32,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "x": 0,
        "y": 0,
        "center": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Aeropeks Settings",
        "url": "/?window=settings",
        "width": 640,
        "height": 720,
        "decorations": true,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "expanded-player",
        "title": "Aeropeks Player",
        "url": "/?window=expanded-player",
        "width": 640,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "terminal-panel",
        "title": "Terminal",
        "url": "/?window=terminal-panel",
        "width": 860,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "launcher-panel",
        "title": "Aeropeks Launcher",
        "url": "/?window=launcher-panel",
        "width": 700,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "taskbar-bottom",
        "title": "Aeropeks Taskbar",
        "url": "/?window=taskbar-bottom",
        "width": 1920,
        "height": 60,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "x": 0,
        "y": 0,
        "center": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}