{
  "productName": "Aeropeks",
  "version": "0.1.4",
  "identifier": "com.aeropeks.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aeropeks",
        "width": 1920,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "x": 0,
        "y": 0,
        "center": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Aeropeks Settings",
        "url": "/?window=settings",
        "width": 920,
        "height": 860,
        "minWidth": 720,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "resizable": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "expanded-player",
        "title": "Aeropeks Player",
        "url": "/?window=expanded-player",
        "width": 640,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "shadow": false,
        "skipTaskbar": true
      },
      {
        "label": "terminal-panel",
        "title": "Terminal",
        "url": "/?window=terminal-panel",
        "width": 860,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "launcher-panel",
        "title": "Aeropeks Launcher",
        "url": "/?window=launcher-panel",
        "width": 700,
        "height": 450,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "demo-weather",
        "title": "Aeropeks Weather",
        "url": "/?window=demo-weather",
        "width": 440,
        "height": 660,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "demo-usage",
        "title": "Aeropeks Usage",
        "url": "/?window=demo-usage",
        "width": 380,
        "height": 360,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "demo-projects",
        "title": "Aeropeks Projects",
        "url": "/?window=demo-projects",
        "width": 420,
        "height": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
